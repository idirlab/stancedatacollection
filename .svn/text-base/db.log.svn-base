2015-04-21 11:58:16:SELECT count(*) as count FROM User WHERE username != "factchecker"
2015-04-21 12:03:59:SELECT ceil(sum(if(answered>=2, 1, 0))/count(*)*100) as PROGRESS FROM Sentence, Speaker_File WHERE Sentence.file_id = Speaker_File.file_id AND Sentence.speaker_id = Speaker_File.speaker_id AND Speaker_File.role = "interviewee" AND Sentence.length >= 5 AND screening = -3
2015-04-21 12:03:59:SELECT count(*) as count FROM Sentence WHERE screening = -3 AND answered >= 2
2015-04-21 12:03:59:SELECT count(*) as count FROM Sentence WHERE screening = -3 AND answered = 1
2015-04-21 12:03:59:SELECT count(*) as count FROM User WHERE username != "factchecker"
2015-04-21 12:48:45:SELECT ceil(sum(if(answered>=2, 1, 0))/count(*)*100) as PROGRESS FROM Sentence, Speaker_File WHERE Sentence.file_id = Speaker_File.file_id AND Sentence.speaker_id = Speaker_File.speaker_id AND Speaker_File.role = "interviewee" AND Sentence.length >= 5 AND screening = -3
2015-04-21 12:48:45:SELECT count(*) as count FROM Sentence WHERE screening = -3 AND answered >= 2
2015-04-21 12:48:45:SELECT count(*) as count FROM Sentence WHERE screening = -3 AND answered = 1
2015-04-21 12:48:45:select V.verdict, count(*) as count from (select 
    Sentence.id, count(*) as C,
	coalesce(if(sum(if(response = -1, 1, 0)) >= 2, -1, null), if(sum(if(response = 0, 1, 0)) >= 2, 0, null), if(sum(if(response = 1, 1, 0)) >= 2, 1, null)) as verdict
from
    Sentence,
    Sentence_User
where
    Sentence.id = Sentence_User.sentence_id
        and screening = - 3
        and response != - 2
		and answered >= 2
group by Sentence.id
having verdict is not null) V

group by V.verdict order by V.verdict
